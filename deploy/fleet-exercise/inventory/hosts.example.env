# Non-secret inventory template for the Scripture fleet exercise.
# Copy to hosts.env (gitignored locally) and fill ZeroTier addresses.
# Never put R2/AWS secret values in this file.

FLEET_EXERCISE_LABEL=lab
FLEET_EXERCISE_BACKEND=r2

# Owner / standby always-on home boxes (pick one as owner).
OWNER_HOST=node-a
OWNER_ZT_IP=10.x.x.x
OWNER_BIND=0.0.0.0:9000
OWNER_ADVERTISE=tcp://10.x.x.x:9000
OWNER_STATUS_BIND=127.0.0.1:9100
OWNER_ID='fleet-lab-own-a!'

STANDBY_HOST=node-b
STANDBY_ZT_IP=10.x.x.y
STANDBY_BIND=0.0.0.0:9000
STANDBY_ADVERTISE=tcp://10.x.x.y:9000
STANDBY_STATUS_BIND=127.0.0.1:9100
STANDBY_ID='fleet-lab-own-b!'

# Optional remote observer (read Canon / status only).
OBSERVER_HOST=josh-oci-work-box-0
OBSERVER_ZT_IP=10.x.x.z

# Producer hosts that run scripture-load over ZeroTier.
PRODUCER_HOSTS=node-c,desktop
LOAD_CONNECTIONS=4
LOAD_RECORD_BYTES=256
LOAD_DURATION_SECS=30
LOAD_MAX_BYTES=8388608

# Path on the operator laptop to the R2 env file (never committed).
# Expected keys: R2_ENDPOINT R2_BUCKET R2_REGION R2_ACCESS_KEY_ID R2_SECRET_ACCESS_KEY
R2_ENV_FILE=$HOME/.config/scripture/r2.env

# Remote path that receives binaries (no secrets).
REMOTE_BIN_DIR=$HOME/scripture-fleet-exercise/bin
REMOTE_SUMMARY_DIR=$HOME/scripture-fleet-exercise/results
