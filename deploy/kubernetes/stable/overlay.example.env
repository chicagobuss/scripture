# Example operator overlay for WP09 (copy to ignored overlay.env).
# Credentials are created as Kubernetes Secrets out-of-band — never listed here.
# Namespace is always scripture-stable-<RUN_ID> (derived by the runner).

KUBE_CONTEXT=Default
RUN_ID=wp09-drill-1
SCRIPTURE_IMAGE=scripture@sha256:REPLACE
RUSTFS_NODE=bignlittles
WRITER_A_NODE=node-a
WRITER_B_NODE=node-b
BUCKET=scripture-stable-wp09-drill-1
