# Example operator overlay for WP09 (copy to ignored overlay.env).
# Credentials are created as Kubernetes Secrets out-of-band — never listed here.
# Namespace is always scripture-stable-<RUN_ID> (derived by the runner).
# Helper images must be digest-pinned for live execute.

KUBE_CONTEXT=Default
RUN_ID=wp09-drill-1
SCRIPTURE_IMAGE=scripture@sha256:REPLACE
RUSTFS_NODE=bignlittles
WRITER_A_NODE=node-a
WRITER_B_NODE=node-b
BUCKET=scripture-stable-wp09-drill-1
RUSTFS_IMAGE=rustfs/rustfs@sha256:fa19210ac4697c79d7ccca1ec9b0eb91aebacc6691991ffb14014bb3c67e6cc3
BUSYBOX_IMAGE=busybox@sha256:73aaf090f3d85aa34ee199857f03fa3a95c8ede2ffd4cc2cdb5b94e566b11662
CURL_IMAGE=curlimages/curl@sha256:08e466006f0860e54fc299378de998935333e0e130a15f6f98482e9f8dab3058
AWS_CLI_IMAGE=amazon/aws-cli@sha256:82acb165ccdc3e3f420b3753787847481d2f835d54582402774ec51fdbdc19ab
