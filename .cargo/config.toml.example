# Example Cargo config for the private `fleet` registry (Kellnr).
# Copy fragments into an ignored operator config (e.g. ~/.cargo/config.toml or
# config/local/kellnr/config.toml via CARGO_HOME). Never commit tokens.
#
# [registries.fleet]
# index = "sparse+REPLACE_WITH_KELLNR_SPARSE_INDEX"
#
# Prefer credential-provider / token-file over inline tokens:
#   registry.global-credential-providers = ["cargo:token"]
#
# Release builds resolve Holylog exclusively from this registry; do not add a
# Git or path fallback to the release source.
